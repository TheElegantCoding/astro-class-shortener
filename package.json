{
  "name": "astro-class-shortener-",
  "description": "📦",
  "author": {
    "name": "Luis Monsalve <TheElegantCoding>",
    "email": "luismonsalve1941@gmail.com"
  },
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/astro-class-shortener.git"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["./dist"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "watch": "tsup --watch",
    "lint": "eslint . --fix ",
    "test-vite": "vite build --config test/vite.config.ts",
    "build": "tsup"
  },
  "dependencies": {
    "postcss-selector-parser": "7.1.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "astro": "6.1.1",
    "eslint-config-universal-code": "^1.0.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
